; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="UKHPC_tour"
run/main_scene="uid://cfaiv1x3dbu0m"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
boot_splash/show_image=false
config/icon="res://icon.svg"
config/quality/msaa_2d=0

[audio]

video/quality/screen_space_aa=2

[autoload]

AvailablePanoramas="*uid://clo6fqquvx5kt"
Signalbus="*uid://0fkvwmu6hvs3"
InteractableObjects="*uid://djd0altg7ymyw"
FloorManager="*uid://ksnd57l3sfr6"
ChunkManager="*uid://bt2t81xak0ren"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"

[global_group]

player=""
door=""
stair_doors=""
inter3d=""

